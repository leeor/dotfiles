# Locale
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# TERM fallback (for missing terminfo over SSH)
if [[ -z "$TERM" ]] || ! infocmp "$TERM" &>/dev/null; then
  export TERM=xterm-256color
fi

# Homebrew
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Go
export GOPATH=$HOME/go
export PATH="/usr/local/go/bin:$GOPATH/bin:$PATH"

# fnm (Node.js)
if [[ -d $HOME/.local/share/fnm ]]; then
  export PATH="$HOME/.local/share/fnm:$PATH"
  eval "$(fnm env --use-on-cd 2>/dev/null)"
fi

# Claude Code
export PATH="$HOME/.local/bin:$PATH"

# XDG
export XDG_CONFIG_HOME=${HOME}/.config
export XDG_CACHE_HOME=${HOME}/.cache

if [[ ! -d "$XDG_CACHE_HOME/zsh" ]]; then
  mkdir -p $XDG_CACHE_HOME/zsh
fi

# Disable marking VCS as dirty due to untracked files (faster status checks)
DISABLE_UNTRACKED_FILES_DIRTY="true"
COMPLETION_WAITING_DOTS="true"
HIST_STAMPS="dd.mm.yyyy"

# zgen {{{

if [[ ! -f $XDG_CACHE_HOME/zgen/zgen.zsh ]]; then
  git clone https://github.com/tarjoilija/zgen.git "${XDG_CACHE_HOME}/zgen"
fi

ZGEN_DIR=${XDG_CACHE_HOME}/zgen.repos
. $XDG_CACHE_HOME/zgen/zgen.zsh

# Fix slowness of pastes with zsh-syntax-highlighting
pasteinit() {
  OLD_SELF_INSERT=${${(s.:.)widgets[self-insert]}[2,3]}
  zle -N self-insert url-quote-magic
}
pastefinish() {
  zle -N self-insert $OLD_SELF_INSERT
}
zstyle :bracketed-paste-magic paste-init pasteinit
zstyle :bracketed-paste-magic paste-finish pastefinish

if ! zgen saved; then
  zgen oh-my-zsh

  zgen oh-my-zsh plugins/git
  zgen oh-my-zsh plugins/node
  zgen oh-my-zsh plugins/npm
  zgen oh-my-zsh plugins/web-search
  zgen oh-my-zsh plugins/docker

  local dotfiles_dir="$(dirname $(readlink ${(%):-%x} 2>/dev/null || echo ${(%):-%x}))"

  zgen load "$dotfiles_dir/plugins/vi-mode"
  zgen load "$dotfiles_dir/plugins/tmuxifier"

  zgen load lukechilds/zsh-better-npm-completion
  zgen load zsh-users/zsh-syntax-highlighting
  zgen load zsh-users/zsh-autosuggestions

  if [[ -d "$dotfiles_dir/themes/pico" ]]; then
    zgen load "$dotfiles_dir/themes/pico"
  fi

  if [[ -f "${(%):-%x}.plugins.$(uname)" ]]; then
    while read -r line; do
      zgen ${=line}
    done < "${(%):-%x}.plugins.$(uname)"
  fi

  zgen save
fi

# Source pico theme explicitly (zgen load only adds to fpath)
local dotfiles_dir="$(dirname $(readlink ${(%):-%x} 2>/dev/null || echo ${(%):-%x}))"
if [[ -f "$dotfiles_dir/themes/pico/pico.zsh-theme" ]]; then
  source "$dotfiles_dir/themes/pico/pico.zsh-theme"
fi

# }}}

# Fix backspace over SSH
bindkey "^?" backward-delete-char
bindkey "^H" backward-delete-char

# Source platform-specific settings
if [[ -a "${(%):-%x}.$(uname)" ]]; then
  source ${(%):-%x}.$(uname)
fi

# Source local settings
if [[ -a "${HOME}/.zshrc.local" ]]; then
  source ${HOME}/.zshrc.local
fi

export PATH="./node_modules/.bin:$PATH"

# fzf (platform-aware)
if type brew &>/dev/null; then
  local fzf_base="$(brew --prefix)/opt/fzf"
  [[ -f "$fzf_base/shell/key-bindings.zsh" ]] && source "$fzf_base/shell/key-bindings.zsh"
  [[ -f "$fzf_base/shell/completion.zsh" ]] && source "$fzf_base/shell/completion.zsh"
fi

[ -f $HOME/.rvm/scripts/rvm ] && source $HOME/.rvm/scripts/rvm

# Load the shell dotfiles
for file in $(dirname ${(%):-%x})/.{shell_exports,shell_aliases,shell_functions,shell_config}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file";
done
unset file

# Completions
if type brew &>/dev/null; then
  FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
fi
autoload -Uz compinit && compinit

export MONO_REPO_PATH=$HOME/repos/mono/master
